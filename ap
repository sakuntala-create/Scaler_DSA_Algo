/**
 * @input A : Integer array
 * 
 * @Output Integer
 */
 import "sort"
func solve(A []int )  (int) {
    sort.Ints(A)

    if len(A)<=2{
        return 1
    }
   
    diff := A[1]-A[0]
    for i:=1;i<len(A); i++{
        if diff != A[i]-A[i-1]{
            return 0
        }
    }
    return 1
}
