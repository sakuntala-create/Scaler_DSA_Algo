/**
 * @input A : String
 * 
 * @Output Integer
 */
func solve(A string )  (int) {
    MOD := 1000000007
    if len(A)==0{
        return 0
    }
    gCount := 0
    agCount := 0
    for i := len(A)-1 ;i>=0; i--{
        if A[i] == 'G'{
            gCount++
        }
        if A[i]== 'A'{
            agCount = (agCount + gCount)% MOD
        }
    }

    return agCount
}
